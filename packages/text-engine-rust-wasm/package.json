{
  "name": "@flowdoc/text-engine-rust-wasm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "External FlowDoc text engine adapter scaffold for future rustybuzz and ICU4X integration.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./browser-assets": "./src/browserAssets.ts",
    "./browser-assets-xr5": "./src/browserAssetsXr5.ts",
    "./browser-assets-mr1": "./src/browserAssetsMr1.ts",
    "./browser-assets-mr1-range": "./src/browserAssetsMr1Range.ts",
    "./live-draft-smoke": "./src/liveDraftSmokeRows.ts",
    "./node": "./src/node.ts",
    "./worker": "./src/worker.ts",
    "./worker-mr1": "./src/workerMr1.ts",
    "./worker-mr1-range": "./src/workerMr1Range.ts"
  },
  "scripts": {
    "rustybuzz:smoke": "cargo run --manifest-path rust-shaper/Cargo.toml -- ../../assets/fonts/Sarabun/Sarabun-Regular.ttf \"สวัสดีครับตูม\" sarabun-regular",
    "rustybuzz:build": "cargo build --manifest-path rust-shaper/Cargo.toml",
    "pdf-font-bakeoff": "node scripts/build-pdf-font-bakeoff.mjs",
    "wasm:build": "wasm-pack build rust-shaper --target web --out-dir ../pkg --out-name flowdoc_text_engine",
    "wasm:build:live-draft-mr1": "wasm-pack build rust-live-draft-engine --target web --out-dir ../pkg-live-draft-mr1 --out-name flowdoc_text_engine_mr1",
    "wasm:build:live-draft-mr1-range": "wasm-pack build rust-live-draft-engine --target web --out-dir ../pkg-live-draft-mr1-range --out-name flowdoc_text_engine_mr1_range",
    "wasm:verify:live-draft-artifacts": "node scripts/verify-live-draft-artifacts.mjs",
    "wasm:check-toolchain": "node scripts/check-wasm-toolchain.mjs",
    "wasm:readiness-smoke": "npm run wasm:check-toolchain",
    "wasm:bootstrap-plan": "node scripts/plan-wasm-toolchain-bootstrap.mjs",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run type-check"
  },
  "dependencies": {
    "@flowdoc/vnext-core": "file:../.."
  }
}

{
  "name": "@flowdoc/vnext-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone FlowDoc vNext core package for the next document model.",
  "scripts": {
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "check": "npm run type-check && npm run test",
    "verify:uat-69c-source-baseline": "node scripts/verify-uat-69c-source-baseline.mjs",
    "verify:uat-69c-section-2-1-adapter": "node packages/uat-realdoc/scripts/verify-69c-section-adapter.mjs",
    "verify:uat-69c-section-2-1-resolution": "node packages/uat-realdoc/scripts/verify-69c-section-resolution.mjs",
    "verify:uat-69c-section-2-1-measured-export": "node packages/uat-realdoc/scripts/verify-69c-section-measured-export.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fixtures/*": "./fixtures/*"
  },
  "files": [
    "src",
    "fixtures",
    "assets",
    "docs",
    "README.md",
    "AGENTS.md"
  ]
}

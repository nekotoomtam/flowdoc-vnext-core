{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@flowdoc/vnext-core": ["src/index.ts"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
